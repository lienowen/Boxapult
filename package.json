{
  "name": "cargo-renegade-standalone",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node tests/mission-session.test.mjs",
    "serve": "python3 -m http.server 5173",
    "check:architecture": "node tools/check-architecture.mjs",
    "check:syntax": "find src -type f -name '*.js' -print0 | xargs -0 -n1 node --check",
    "check": "npm run check:architecture && npm run check:syntax && npm test"
  }
}
