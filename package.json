{
  "name": "boxapult",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "check:architecture": "node tools/check-architecture.mjs",
    "check": "npm run check:architecture && npm run test && npm run build"
  },
  "dependencies": {
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}
